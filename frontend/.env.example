# ─── Clerk ───────────────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
# Run `npx clerk env pull` to populate .env.local automatically
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk redirect URLs (keep as-is for Pages Router)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Solana ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_CLUSTER=devnet

# ─── Mux (video) ─────────────────────────────────────────────────────────────
# Get these from https://dashboard.mux.com → Settings → Access Tokens
MUX_TOKEN_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# WARNING: MUX_TOKEN_SECRET and CLERK_SECRET_KEY are server-side secrets only.
# NEVER prefix them with NEXT_PUBLIC_ — doing so exposes them to the browser.
MUX_TOKEN_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
