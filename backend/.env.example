# =============================================================================
# DATABASE_URL — Supabase Postgres connection string
# =============================================================================
# Get it from: Supabase dashboard -> Project Settings -> Database -> Connection string
# Project: https://kfwdhtzejhwvhjhlhokn.supabase.co
#
# SSL is REQUIRED by Supabase. Append `?sslmode=require` to the string.
#
# There are TWO strings you may need (use the right one for the right context):
#
# 1) APP RUNTIME (serverless / Cloud Run, many short-lived connections)
#    Transaction pooler (Supavisor), port 6543, IPv4-friendly:
#    postgres://postgres.<project-ref>:<PASSWORD>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require
#    NOTE: the transaction pooler does NOT support prepared statements.
#
# 2) MIGRATIONS (the separate migration Job) and long-lived/admin tooling.
#    Use the Direct connection (port 5432, IPv6) OR the Session pooler
#    (Supavisor, port 5432, IPv4) -- both support prepared statements:
#    Direct:  postgresql://postgres:<PASSWORD>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
#    Session: postgres://postgres.<project-ref>:<PASSWORD>@aws-<region>.pooler.supabase.com:5432/postgres?sslmode=require
#
# Paste your chosen string below (placeholder shown -- replace it):
DATABASE_URL=postgres://postgres.<project-ref>:<PASSWORD>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require

# Payload secret used to sign/encrypt auth tokens. Use a strong, random 32-byte
# value (do NOT reuse across environments). Generate one with:
#   openssl rand -hex 32
PAYLOAD_SECRET=replace-me-with-output-of-openssl-rand-hex-32

# Frontend dev origin allowed for CORS/CSRF (Next.js Pages Router app)
FRONTEND_URL=http://localhost:3000

# Local dev only: set to "true" to let Drizzle auto-push schema (skips migrations).
# NEVER set this in production -- production relies solely on migration files.
# PAYLOAD_DB_PUSH=true
