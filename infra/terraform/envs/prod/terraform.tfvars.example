// Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
// These are PLACEHOLDERS — replace with your real GCP values.
// Do NOT put real secret values here. db_user_password comes from the env:
// export TF_VAR_db_user_password="$(read from your secret store)".

project_id = "melearn-prod-000000" # <-- your prod GCP project ID
region     = "asia-southeast1"     # Singapore

artifact_repository_id = "melearn"
image_tag              = "latest" # CI overrides this with the git SHA

# Bump min_instances to 1 if you want to eliminate cold starts (costs more).
frontend_min_instances = 0
frontend_max_instances = 4
backend_min_instances  = 0
backend_max_instances  = 4

# ---- Cloud SQL (prod) ----
db_version             = "POSTGRES_16"
db_tier                = "db-custom-2-7680" # 2 vCPU / 7.5GB — dedicated, NOT shared-core
db_availability_type   = "REGIONAL"         # HA
db_disk_size           = 20
db_deletion_protection = true
db_pitr_enabled        = true
db_name                = "melearn"
db_user_name           = "melearn_app"
# db_user_password — DO NOT set here. Provide via TF_VAR_db_user_password.

# ---- WIF ----
github_repository = "your-org/melearn"

# ---- Observability ----
alert_email     = "aione.solutions.th@gmail.com"
billing_account = null  # e.g. "0X0X0X-0X0X0X-0X0X0X" to enable the budget alert
budget_amount   = 200
budget_currency = "USD"

frontend_public_env = {
  NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY = "pk_live_xxxxxxxxxxxxxxxxxxxx"
  NEXT_PUBLIC_SOLANA_CLUSTER        = "mainnet-beta"
}

backend_allow_public_access = true
deletion_protection         = true
